<div class="contextual">
  <% if @response.project.present? %>
    <%= link_to sprite_icon('comments', l(:label_all_responses_for_project)), project_responses_path(@response.project.id), class: "icon" %>
  <% else %>
    <%= link_to sprite_icon('comments', l(:label_all_responses)), responses_path, class: "icon" %>
  <% end %>
</div>
<% if @response.project.present? %>
  <h2><%=l(:label_new_response_for_project)%></h2>
<% else %>
  <h2><%=l(:label_new_response)%></h2>
<% end %>
<div id="all_attributes">
  <%= render :partial => 'responses/form' %>
</div>
